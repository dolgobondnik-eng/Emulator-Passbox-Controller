}

// RU: СЂР°Р±РѕС‡РёР№ РґРёР°РїР°Р·РѕРЅ РґРѕР»Р¶РµРЅ Р±С‹С‚СЊ РєРѕСЂСЂРµРєС‚РЅС‹Рј (workMin < workMax)
// EN: working range must be valid (workMin < workMax)
// CN: е·ҐдЅњиЊѓе›ґеї…йЎ»жњ‰ж•€ (workMin < workMax)
if (isFinite(workMin) && isFinite(workMax) && workMin >= workMax) {
    workMax = workMin + 1;
    workMaxInput.value = workMax;
}

            
            const oldWorkMin = room.workMin;
