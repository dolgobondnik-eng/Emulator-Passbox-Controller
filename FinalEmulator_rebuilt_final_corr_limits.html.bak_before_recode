            addEmulatorLogEntry(1, 'info', 'emulationStoppedByAlarm');
        }
        
        // Р—Р°РїСѓСЃРє С‚Р°Р№РјРµСЂР° РЈР¤
        function startUVTimer() {
            saveTimeSettings();
            uvRemainingSeconds = sterilizationTimeSeconds;
            updateUVTimerDisplay();
            if (uvTimerInterval) clearInterval(uvTimerInterval);
            uvTimerInterval = setInterval(() => {
                uvRemainingSeconds--;
                updateUVTimerDisplay();
                if (uvRemainingSeconds <= 0) {
                    clearInterval(uvTimerInterval);
                    uvTimerInterval = null;
                    turnOffUV();
                }
            }, 1000);
        }
        
        // РћР±РЅРѕРІР»РµРЅРёРµ РѕС‚РѕР±СЂР°Р¶РµРЅРёСЏ С‚Р°Р№РјРµСЂР° РЈР¤
        function updateUVTimerDisplay() {
            const minutes = Math.floor(uvRemainingSeconds / 60);
            const seconds = uvRemainingSeconds % 60;
            document.getElementById('uvMinutes').textContent = minutes;
            document.getElementById('uvSeconds').textContent = seconds;
        }
        
        // Р’С‹РєР»СЋС‡РµРЅРёРµ РЈР¤
        function turnOffUV() { 
            const i = document.getElementById('indicator-uv'), t = document.getElementById('text-uv'), l = document.getElementById('uv-lamp'); 
            i.classList.remove('active'); 
            t.innerText = translations[currentLang].uvOff; 
            l.classList.remove('on'); 
        }
        
        // Р—Р°РїСѓСЃРє С‚Р°Р№РјРµСЂР° РѕР±РґСѓРІР°
        function startBlowTimer() {
            saveTimeSettings();
            blowRemainingSeconds = airShowerTimeSeconds;
            updateBlowTimerDisplay();
            if (blowTimerInterval) clearInterval(blowTimerInterval);
            blowTimerInterval = setInterval(() => {
                blowRemainingSeconds--;
                updateBlowTimerDisplay();
                if (blowRemainingSeconds <= 0) {
                    clearInterval(blowTimerInterval);
                    blowTimerInterval = null;
                    turnOffBlow();
                }
            }, 1000);
        }
        
        // РћР±РЅРѕРІР»РµРЅРёРµ РѕС‚РѕР±СЂР°Р¶РµРЅРёСЏ С‚Р°Р№РјРµСЂР° РѕР±РґСѓРІР°
        function updateBlowTimerDisplay() {
            const minutes = Math.floor(blowRemainingSeconds / 60);
            const seconds = blowRemainingSeconds % 60;
            document.getElementById('blowMinutes').textContent = minutes;
            document.getElementById('blowSeconds').textContent = seconds;
        }
        
        // Р’С‹РєР»СЋС‡РµРЅРёРµ РѕР±РґСѓРІР°
        function turnOffBlow() { 
            const i = document.getElementById('indicator-blow'), t = document.getElementById('text-blow'), f = document.getElementById('main-fan'); 
            i.classList.remove('active'); 
            t.innerText = translations[currentLang].blowOff; 
            f.classList.remove('spinning'); 
        }
        
        // Р‘Р»РѕРєРёСЂРѕРІРєР° РєРЅРѕРїРѕРє РІ Р°РІС‚РѕРјР°С‚РёС‡РµСЃРєРѕРј СЂРµР¶РёРјРµ
        function updateButtonsLockState() { 
            const b = document.getElementById('blowWrapper'), u = document.getElementById('uvWrapper'); 
            if (autoModeEnabled) { 
                b.classList.add('disabled'); 
                u.classList.add('disabled'); 
            } else { 
                b.classList.remove('disabled'); 
                u.classList.remove('disabled'); 
            } 
        }
        
        // Р—Р°РїСѓСЃРє РїСЂРѕРІРµСЂРєРё РѕС‚РєСЂС‹С‚С‹С… РґРІРµСЂРµР№
        
/**
 * Р—Р°РїСѓСЃРє РїСЂРѕРІРµСЂРєРё РѕС‚РєСЂС‹С‚С‹С… РґРІРµСЂРµР№.
 * Start monitoring opened doors.
 * еђЇеЉЁй—ЁејЂеђЇз›‘жЋ§гЂ‚
 */
function startDoorOpenCheck() {
    // RU: Р·Р°С‰РёС‚Р° РѕС‚ РїРѕРІС‚РѕСЂРЅРѕРіРѕ Р·Р°РїСѓСЃРєР° (С‡С‚РѕР±С‹ РЅРµ РїР»РѕРґРёС‚СЊ РёРЅС‚РµСЂРІР°Р»С‹)
    // EN: prevent multiple intervals
    // CN: йІж­ўй‡Ќе¤Ќе€›е»єе®љж—¶е™Ё
    if (doorOpenCheckInterval) return;

    doorOpenCheckInterval = setInterval(() => {
        const now = Date.now();
        let anyDoorOpen = false;
        let alarmTriggered = false;

        ['door1', 'door2'].forEach(doorKey => {
            const door = doorState[doorKey];
            if (door.isOpen) {
                anyDoorOpen = true;
                const openDuration = Math.floor((now - door.openStartTime) / 1000);

                if (openDuration >= doorOpenTimeoutSeconds && !door.alarmTriggered) {
                    door.alarmTriggered = true;
                    alarmTriggered = true;
                    // РРЎРџР РђР’Р›Р•РќРћ: РСЃРїРѕР»СЊР·СѓРµРј РїСЂР°РІРёР»СЊРЅС‹Рµ РєР»СЋС‡Рё РґР»СЏ РїРµСЂРµРІРѕРґР°
                    const alarmKey = doorKey === 'door1' ? 'alarm9' : 'alarm1';
                    addAlarm(alarmKey, 'doorOpen');
                }
            }
        });

        const alarmIndicator = document.getElementById('doorOpenAlarm');
        if (alarmTriggered) {
            alarmIndicator.classList.add('show');
        } else if (!anyDoorOpen) {
            alarmIndicator.classList.remove('show');
        }

        if (anyDoorOpen) {
            updateDoorTimerDisplay();
        }
    }, 100);
}

        // РћР±РЅРѕРІР»РµРЅРёРµ РѕС‚РѕР±СЂР°Р¶РµРЅРёСЏ С‚Р°Р№РјРµСЂР° РґРІРµСЂРё
        function updateDoorTimerDisplay() {
            const timerElement = document.getElementById('doorTimer');
            const now = Date.now();
            let openDuration = 0;
            let isDoorOpen = false;
            
            ['door1', 'door2'].forEach(doorKey => {
                const door = doorState[doorKey];
                if (door.isOpen) {
                    isDoorOpen = true;
                    openDuration = Math.floor((now - door.openStartTime) / 1000);
                }
            });
            
            if (isDoorOpen) {
                timerElement.classList.add('show');
                timerElement.classList.remove('counting');
                if (openDuration >= doorOpenTimeoutSeconds) {
                    timerElement.classList.add('alarm');
                } else {
                    timerElement.classList.remove('alarm');
                }
                const text = translations[currentLang].doorOpen;
                timerElement.textContent = `${text}: ${openDuration} ${translations[currentLang].sec}`;
            } else {
                timerElement.classList.remove('show', 'counting', 'alarm');
            }
        }
        
        // РџРµСЂРµРєР»СЋС‡РµРЅРёРµ СЃРѕСЃС‚РѕСЏРЅРёСЏ РґРІРµСЂРё
        function toggleDoor(n) {
            const k = `door${n}`, o = n === 1 ? 'door2' : 'door1', now = Date.now();
            if (doorState[k].isBlocked) return;
            if (!doorState[k].isOpen) {
                if (doorState[o].isOpen) return;
                if (now - doorState[o].lastCloseTime < DOOR_INTERLOCK_DELAY && doorState[o].lastCloseTime !== 0) return;
                doorState[k].isOpen = true;
                doorState[k].openStartTime = now;
                doorState[k].alarmTriggered = false;
                updateDoorVisual(n, true);
                doorState[o].isBlocked = true;
                updateLockVisual(o === 'door1' ? 1 : 2, true);
                startDoorOpenCheck();
            } else {
                doorState[k].isOpen = false;
                doorState[k].lastCloseTime = now;
                doorState[k].alarmTriggered = false;
                updateDoorVisual(n, false);
                doorState[k].isBlocked = false;
                updateLockVisual(n, false);
                startInterlockTimer(o === 'door1' ? 1 : 2);
                
                if (!doorState.door1.isOpen && !doorState.door2.isOpen) {
                    document.getElementById('doorOpenAlarm').classList.remove('show');
                    if (doorOpenCheckInterval) {
                        clearInterval(doorOpenCheckInterval);
                        doorOpenCheckInterval = null;
                    }
                }
                
                if (!autoModeEnabled) {
                    if (n === 1) {
                        if (autoStartSettings.uvDoor1 && !document.getElementById('indicator-uv').classList.contains('active')) {
                            autoStartUV();
                        }
                        if (autoStartSettings.blowDoor1 && !document.getElementById('indicator-blow').classList.contains('active')) {
                            autoStartBlow();
                        }
                    } else if (n === 2) {
                        if (autoStartSettings.uvDoor2 && !document.getElementById('indicator-uv').classList.contains('active')) {
                            autoStartUV();
                        }
                        if (autoStartSettings.blowDoor2 && !document.getElementById('indicator-blow').classList.contains('active')) {
                            autoStartBlow();
                        }
                    }
                }
            }
        }
        
        // РђРІС‚РѕРјР°С‚РёС‡РµСЃРєРёР№ Р·Р°РїСѓСЃРє РЈР¤
        function autoStartUV() {
            const indicator = document.getElementById('indicator-uv');
            const textElement = document.getElementById('text-uv');
            const uvLamp = document.getElementById('uv-lamp');
            indicator.classList.add('active');
            textElement.innerHTML = translations[currentLang].uvOn;
            uvLamp.classList.add('on');
            startUVTimer();
        }
        
        // РђРІС‚РѕРјР°С‚РёС‡РµСЃРєРёР№ Р·Р°РїСѓСЃРє РѕР±РґСѓРІР°
        function autoStartBlow() {
            const indicator = document.getElementById('indicator-blow');
            const textElement = document.getElementById('text-blow');
            const fan = document.getElementById('main-fan');
            indicator.classList.add('active');
            textElement.innerHTML = translations[currentLang].blowOn;
            fan.classList.add('spinning');
            startBlowTimer();
        }
        
        // РћР±РЅРѕРІР»РµРЅРёРµ РІРёР·СѓР°Р»СЊРЅРѕРіРѕ СЃРѕСЃС‚РѕСЏРЅРёСЏ РґРІРµСЂРё
        function updateDoorVisual(n, open) { 
            const c = document.getElementById(`door${n}-closed`), o = document.getElementById(`door${n}-open`); 
            if (open) { 
                c.classList.add('hidden'); 
                o.classList.remove('hidden'); 
            } else { 
                c.classList.remove('hidden'); 
                o.classList.add('hidden'); 
            } 
        }
        
        // РћР±РЅРѕРІР»РµРЅРёРµ РІРёР·СѓР°Р»СЊРЅРѕРіРѕ СЃРѕСЃС‚РѕСЏРЅРёСЏ Р·Р°РјРєР°
        function updateLockVisual(n, blocked) { 
            const s = document.getElementById(`lock${n}`), h = document.getElementById(`lock${n}-shackle`); 
            if (blocked) { 
                s.classList.remove('lock-unlocked'); 
                s.classList.add('lock-blocked'); 
                h.setAttribute('d', 'M15 25 V 15 A 10 10 0 0 1 35 15 V 25'); 
                h.style.display = 'block'; 
            } else { 
                s.classList.remove('lock-blocked'); 
                s.classList.add('lock-unlocked'); 
                h.setAttribute('d', 'M 10 25 A 15 15 0 0 1 40 25'); 
                h.style.display = 'block'; 
            } 
        }
        
        // Р—Р°РїСѓСЃРє С‚Р°Р№РјРµСЂР° Р±Р»РѕРєРёСЂРѕРІРєРё РґРІРµСЂРё
        
/**
 * Р—Р°РїСѓСЃРє С‚Р°Р№РјРµСЂР° Р±Р»РѕРєРёСЂРѕРІРєРё РґРІРµСЂРё.
 * Start door interlock timer.
 * еђЇеЉЁй—Ёдє’й”Ѓи®Ўж—¶е™ЁгЂ‚
 */
function startInterlockTimer(n) { 
    const t = document.getElementById('doorTimer'); 
    let r = Math.ceil(DOOR_INTERLOCK_DELAY / 1000); 

    // RU: Р±РµР·РѕРїР°СЃРЅРѕ СЃР±СЂР°СЃС‹РІР°РµРј РїСЂРµРґС‹РґСѓС‰РёР№ С‚Р°Р№РјРµСЂ
    // EN: safely clear previous timer
    // CN: е®‰е…Ёжё…й™¤д№‹е‰Ќзљ„е®љж—¶е™Ё
    if (doorTimerInterval) { 
        clearInterval(doorTimerInterval); 
        doorTimerInterval = null; 
    }

    t.classList.add('show', 'counting'); 
    updateTimerDisplay(r); 

    doorTimerInterval = setInterval(() => { 
        r--; 
        if (r > 0) updateTimerDisplay(r); 
        else { 
            clearInterval(doorTimerInterval); 
            doorTimerInterval = null; 
            doorState[`door${n}`].isBlocked = false; 
            updateLockVisual(n, false); 
            t.classList.remove('show', 'counting'); 
        } 
    }, 1000); 
}

        // РћР±РЅРѕРІР»РµРЅРёРµ РѕС‚РѕР±СЂР°Р¶РµРЅРёСЏ С‚Р°Р№РјРµСЂР°
        function updateTimerDisplay(s) { 
            const t = document.getElementById('doorTimer'); 
            if (!t.classList.contains('show')) return; 
            const w = translations[currentLang].waiting; 
            const st = currentLang === 'zh' ? 'з§’' : currentLang === 'en' ? 'sec' : 'СЃРµРє'; 
            t.textContent = `${w}: ${s} ${st}`; 
        }
        
        // РџРµСЂРµРєР»СЋС‡РµРЅРёРµ СЃС‚Р°С‚СѓСЃР° РѕР±РґСѓРІР°
        function toggleStatus(id, tid, off, on) { 
            if (autoModeEnabled) return; 
            const i = document.getElementById(id), t = document.getElementById(tid); 
            if (i.classList.contains('active')) { 
                i.classList.remove('active'); 
                t.innerHTML = translations[currentLang][off]; 
                if (blowTimerInterval) { 
                    clearInterval(blowTimerInterval); 
                    blowTimerInterval = null; 
                } 
                blowRemainingSeconds = 0; 
                updateBlowTimerDisplay(); 
            } else { 
                i.classList.add('active'); 
                t.innerHTML = translations[currentLang][on]; 
                startBlowTimer(); 
            } 
            if (tid === 'text-blow') { 
                const f = document.getElementById('main-fan'); 
                if (i.classList.contains('active')) f.classList.add('spinning'); 
                else f.classList.remove('spinning'); 
            } 
        }
        
        // РџРµСЂРµРєР»СЋС‡РµРЅРёРµ СЃС‚Р°С‚СѓСЃР° СЃРІРµС‚Р°
        function toggleLight(id, tid, off, on) { 
            const i = document.getElementById(id), t = document.getElementById(tid), l = document.getElementById('led-light'); 
            if (i.classList.contains('active')) { 
                i.classList.remove('active'); 
                t.innerHTML = translations[currentLang][off]; 
                l.classList.remove('on'); 
            } else { 
                i.classList.add('active'); 
                t.innerHTML = translations[currentLang][on]; 
                l.classList.add('on'); 
            } 
        }
        
        // РџРµСЂРµРєР»СЋС‡РµРЅРёРµ СЃС‚Р°С‚СѓСЃР° РЈР¤
        function toggleUV(id, tid, off, on) { 
            if (autoModeEnabled) return; 
            const i = document.getElementById(id), t = document.getElementById(tid), l = document.getElementById('uv-lamp'); 
            if (i.classList.contains('active')) { 
                i.classList.remove('active'); 
                t.innerHTML = translations[currentLang][off]; 
                l.classList.remove('on'); 
                if (uvTimerInterval) { 
                    clearInterval(uvTimerInterval); 
                    uvTimerInterval = null; 
                } 
                uvRemainingSeconds = 0; 
                updateUVTimerDisplay(); 
            } else { 
                i.classList.add('active'); 
                t.innerHTML = translations[currentLang][on]; 
                l.classList.add('on'); 
                startUVTimer(); 
            } 
        }
        
        // РџРµСЂРµРєР»СЋС‡РµРЅРёРµ СЂРµР¶РёРјР° (СЂСѓС‡РЅРѕР№/Р°РІС‚РѕРјР°С‚РёС‡РµСЃРєРёР№)
        
/**
 * РџРµСЂРµРєР»СЋС‡РµРЅРёРµ СЂРµР¶РёРјР° (СЂСѓС‡РЅРѕР№/Р°РІС‚РѕРјР°С‚РёС‡РµСЃРєРёР№).
 * Toggle manual/auto mode.
 * е€‡жЌўж‰‹еЉЁ/и‡ЄеЉЁжЁЎејЏгЂ‚
 */
function toggleMode(id, tid, m1, m2) { 
    const i = document.getElementById(id), t = document.getElementById(tid); 

    // RU: РЅРµ СЃСЂР°РІРЅРёРІР°РµРј С‚РµРєСЃС‚ (innerHTML) вЂ” СЌС‚Рѕ Р»РѕРјР°РµС‚СЃСЏ РїСЂРё РїРµСЂРµРІРѕРґР°С…/С„РѕСЂРјР°С‚РёСЂРѕРІР°РЅРёРё
    // EN: don't rely on innerHTML comparison (breaks with translations/formatting)
    // CN: дёЌи¦Ѓдѕќиµ– innerHTML жЇ”иѕѓпј€зї»иЇ‘/ж јејЏеЏеЊ–дјљеЇји‡ґй”™иЇЇпј‰
    autoModeEnabled = !autoModeEnabled;

    if (autoModeEnabled) { 
        t.innerHTML = translations[currentLang][m2]; 
        i.classList.add('active'); 
    } else { 
        t.innerHTML = translations[currentLang][m1]; 
        i.classList.remove('active'); 
    } 
    updateButtonsLockState(); 
}

        // РџРµСЂРµРєР»СЋС‡РµРЅРёРµ РЅР°СЃС‚СЂРѕР№РєРё (РІРєР»/РІС‹РєР»)
        function toggleSetting(btn) { 
            if (btn.classList.contains('active')) { 
                btn.classList.remove('active'); 
                btn.innerHTML = translations[currentLang].no; 
            } else { 
                btn.classList.add('active'); 
                btn.innerHTML = translations[currentLang].yes; 
            } 
        }
        // Update panel clock

/**
 * Update time on the panel.
 */
function updateTime() { 
    const n = new Date(); 
    // Locale depends on currently selected language.
    const locale = currentLang === 'en' ? 'en-US' : (currentLang === 'zh' ? 'zh-CN' : 'ru-RU');

    document.getElementById('datetime').innerText = `${n.toLocaleDateString(locale)} ${n.toLocaleTimeString(locale)}`; 
}
        // Page initialization on load

        window.addEventListener('load', function() { 
            currentLang = 'ru'; 
            updateAllTexts(); 
            setInterval(updateTime, 1000); 
            updateTime(); 
            updateUVTimerDisplay(); 
            updateBlowTimerDisplay(); 
            updateAutoButtons(); 
            saveTimeSettings(); 
            loadDoorTimeoutSetting(); 
            
            // make sure the charts exist before any emulator logic touches them
            ensureEmulatorChartsInitialized();
            // Initialize emulator status labels.
            updateEmulatorRoomStatus(1);
            updateEmulatorRoomStatus(2);

            // Set default slider labels.
            document.getElementById('emulatorSpeedValue1').textContent = '1.0x';
            document.getElementById('emulatorSpeedValue2').textContent = '1.0x';
            document.getElementById('emulatorSmoothValue1').textContent = '0.50';
            document.getElementById('emulatorSmoothValue2').textContent = '0.50';
            document.getElementById('emulatorOverValue1').textContent = '0.20';
            document.getElementById('emulatorOverValue2').textContent = '0.20';
            // Load initial chart boundary values.
            document.getElementById('min1').value = emulatorRooms[0].min;
            document.getElementById('max1').value = emulatorRooms[0].max;
            document.getElementById('workMin1').value = emulatorRooms[0].workMin;
            document.getElementById('workMax1').value = emulatorRooms[0].workMax;
            document.getElementById('min2').value = emulatorRooms[1].min;
            document.getElementById('max2').value = emulatorRooms[1].max;
            document.getElementById('workMin2').value = emulatorRooms[1].workMin;
            document.getElementById('workMax2').value = emulatorRooms[1].workMax;
            
            // Р”РѕР±Р°РІР»СЏРµРј РїСЂРёРјРµСЂ С‚СЂРµРІРѕРіРё РґР»СЏ РґРµРјРѕРЅСЃС‚СЂР°С†РёРё
            // Demo alarm is intentionally disabled in production startup flow.
    // Sync parameter settings fields with current emulator working limits.
    ['1','2'].forEach((n, i) => {
        const idx = i + 1;
        const sMin = document.getElementById(`settingWorkMin${idx}`);
        const sMax = document.getElementById(`settingWorkMax${idx}`);
        if (sMin) sMin.value = String(emulatorRooms[i].workMin);
        if (sMax) sMax.value = String(emulatorRooms[i].workMax);
    });

    bindCorrectionInputs();
    savePressureAlarmDelay();
    setDPPriority(dpPriority);
    updatePressurePanel();
});

// РћР±СЂР°Р±РѕС‚С‡РёРє РёР·РјРµРЅРµРЅРёСЏ СЂР°Р·РјРµСЂР° РѕРєРЅР° РґР»СЏ СЌРјСѓР»СЏС‚РѕСЂР° (debounce)
// RU: СЃРЅРёР¶Р°РµС‚ РЅР°РіСЂСѓР·РєСѓ РїСЂРё РїРµСЂРµС‚СЏРіРёРІР°РЅРёРё РѕРєРЅР°
// EN: reduces CPU usage during resize
// CN: е‡Џе°‘зЄ—еЏЈж‹–еЉЁж—¶зљ„CPUеЌ з”Ё
let resizeTimeout = null;
window.addEventListener('resize', () => {
    if (resizeTimeout) clearTimeout(resizeTimeout);
    resizeTimeout = setTimeout(() => {
        emulatorRooms.forEach((room, index) => {
            const canvas = document.getElementById(room.id);
            if (canvas && Array.isArray(emulatorCharts) && emulatorCharts[index]) {
                canvas.width = canvas.parentElement.clientWidth;
                canvas.height = 170;
                emulatorCharts[index].resize();
            }
        });
    }, 150);
});
</script>
