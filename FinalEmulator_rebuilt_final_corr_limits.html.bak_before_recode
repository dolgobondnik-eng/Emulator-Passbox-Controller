function updatePressurePanel() {
    // RU: Р±РµСЂС‘Рј "СЂРµР°Р»СЊРЅС‹Рµ" Р·РЅР°С‡РµРЅРёСЏ РёР· СЌРјСѓР»СЏС‚РѕСЂР° Рё РїСЂРёРјРµРЅСЏРµРј РєРѕСЂСЂРµРєС†РёРё С‚РѕР»СЊРєРѕ Рє РѕС‚РѕР±СЂР°Р¶РµРЅРёСЋ
    // EN: take emulator "real" values and apply corrections to display only
    // CN: д»ЋжЁЎж‹џе™ЁиЋ·еЏ–вЂњзњџе®ћвЂќеЂјпјЊд»…еЇ№жѕз¤єеє”з”Ёдї®ж­Ј
    const room1 = emulatorRooms[0];
