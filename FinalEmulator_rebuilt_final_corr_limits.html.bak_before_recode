    const r1 = Number.isFinite(room1?.currentPressure) ? room1.currentPressure : 0;
    const r2 = Number.isFinite(room2?.currentPressure) ? room2.currentPressure : 0;

    // HEPA: Р±Р°Р·РѕРІРѕРµ 60 РџР° + РєРѕСЂСЂРµРєС†РёСЏ С„РёР»СЊС‚СЂР° (РєР°Рє РїСЂРѕСЃРёР»)
    const hepaValEl = document.querySelector('.pressure-block .pressure-row .p-val'); // РїРµСЂРІР°СЏ СЃС‚СЂРѕРєР° HEPA
    if (hepaValEl) hepaValEl.textContent = String(Math.round(60 + filterCorrection));

