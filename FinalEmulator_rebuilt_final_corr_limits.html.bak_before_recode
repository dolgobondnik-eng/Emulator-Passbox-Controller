        function ensureEmulatorChartsInitialized() {
            try {
                if (typeof Chart === 'undefined') {
                    console.error('Chart.js is not loaded (Chart is undefined).');
                    markChartUnavailable();
                    return false;
                }
                // emulatorCharts РјРѕР¶РµС‚ Р±С‹С‚СЊ РЅРµ СЃРѕР·РґР°РЅ, РµСЃР»Рё РІ РєРѕРґРµ СЂР°РЅРµРµ Р±С‹Р»Р° РѕС€РёР±РєР° РІС‹РїРѕР»РЅРµРЅРёСЏ.
                if (!window.emulatorCharts || !Array.isArray(window.emulatorCharts)) {
                    console.warn('emulatorCharts is missing, initializing...');
                    window.emulatorCharts = emulatorRooms.map((room) => {
                        const canvas = document.getElementById(room.id);
                        if (!canvas) return null;
                        canvas.style.width = '100%';
                        canvas.style.height = '170px';
                        canvas.width = canvas.parentElement?.clientWidth || 800;
                        canvas.height = 170;
                        const ctx = canvas.getContext('2d');
                        const borderColor = getRandomColor();
                        return new Chart(ctx, {
                            type: 'line',
                            data: {
                                datasets: [
                                    { label: 'Р”Р°РІР»РµРЅРёРµ (РџР°)', data: [], borderColor, backgroundColor: 'rgba(0,0,0,0)', borderWidth: 2, pointRadius: 0, fill: false, tension: 0.1 },
                                    { label: 'Р Р°Р±РѕС‡РёР№ Min', data: [], borderColor: 'red', borderDash: [5,5], pointRadius: 0, fill: false, borderWidth: 1.5 },
                                    { label: 'Р Р°Р±РѕС‡РёР№ Max', data: [], borderColor: 'blue', borderDash: [5,5], pointRadius: 0, fill: false, borderWidth: 1.5 }
                                ]
                            },
                            options: {
                                responsive: true,
                                maintainAspectRatio: false,
                                animation: false,
                                scales: {
                                    y: { min: room.min, max: room.max, title: { display: false }, grid: { color: 'rgba(0,0,0,0.1)' }, ticks: { font: { size: 9 } } },
                                    x: { type: 'linear', title: { display: false }, min: 0, max: windowSizeMinutes, grid: { color: 'rgba(0,0,0,0.1)' },
                                         ticks: { callback: (value) => value.toFixed(1), maxTicksLimit: 5, font: { size: 8 } } }
                                },
                                plugins: {
                                    title: { display: false },
                                    legend: { display: false },
                                    tooltip: {
                                        callbacks: {
                                            label: (context) => context.parsed.y.toFixed(1) + ' РџР°',
                                            title: (context) => 'Р’СЂРµРјСЏ: ' + context[0].parsed.x.toFixed(2) + ' РјРёРЅ'
                                        }
                                    }
                                }
                            }
                        });
                    });
                    // reflect global array in local variable for legacy code paths
                    emulatorCharts = window.emulatorCharts;
                } else {
                    // if charts already existed globally make sure local handle stays in sync
                    emulatorCharts = window.emulatorCharts;
                }
                // РїСЂРѕРІРµСЂСЏРµРј С‡С‚Рѕ chart РѕР±СЉРµРєС‚С‹ РµСЃС‚СЊ
                if (window.emulatorCharts.some(c => c == null)) {
                    console.warn('Some emulator charts are null (missing canvas?).');
                    // РЅРѕ РІСЃС‘ СЂР°РІРЅРѕ РїРѕР·РІРѕР»СЏРµРј СЃС‚Р°СЂС‚РѕРІР°С‚СЊ, РїСЂРѕСЃС‚Рѕ СЌС‚Рё РіСЂР°С„РёРєРё РЅРµ Р±СѓРґСѓС‚ РѕР±РЅРѕРІР»СЏС‚СЊСЃСЏ
                }
                return true;
            } catch (e) {
                console.error('Failed to initialize emulator charts:', e);
                markChartUnavailable();
                return false;
            }
        }

function startEmulator() {
            if (!ensureEmulatorChartsInitialized()) {
                console.warn('Emulator start skipped: Chart.js is unavailable.');
                return;
            }

            clearEmulatorLog();
            
            emulatorRooms.forEach((room, index) => {
                room.isRunning = true;
                room.currentTime = 0;
                room.data = [];
                room.lastPressure = null;
                room.targetPressure = null;
                room.lastStatus = 'normal';
                room.statusStartTime = 0;
                
                if (emulatorCharts[index]) {
                    emulatorCharts[index].data.labels = [];
                    emulatorCharts[index].data.datasets[0].data = [];
                }
                
                updateEmulatorRoomStatus(index + 1);
            });

            addEmulatorLogEntry(1, 'info', 'emulationStarted');
            addEmulatorLogEntry(2, 'info', 'emulationStarted');

            if (emulatorIntervalId) {
                clearInterval(emulatorIntervalId);
            }
            emulatorIntervalId = setInterval(generateEmulatorNextPoints, sampleRate * 1000);
            document.getElementById('emulatorStartBtn').disabled = true;
            document.getElementById('emulatorStartBtn').style.opacity = '0.5';
        }

        // Р“РµРЅРµСЂР°С†РёСЏ РґР°РЅРЅС‹С… СЌРјСѓР»СЏС‚РѕСЂР° (РІС‹Р·С‹РІР°РµС‚СЃСЏ РїРѕ С‚Р°Р№РјРµСЂСѓ)
        function generateEmulatorNextPoints() {
            let anyRunning = false;
            
            emulatorRooms.forEach((room, i) => {
                if (!room.isRunning) {
                    updateEmulatorMinMaxLines(room, emulatorCharts[i], room.currentTime);
                    return;
                }
                
                anyRunning = true;
                
                const chart = emulatorCharts[i];
                if (!chart) return;
                
                const tSeconds = Math.round((room.currentTime + sampleRate * room.speed) * 100) / 100;
                room.currentTime = tSeconds;
                
                const tMinutes = tSeconds * SEC_TO_MIN;
                const roundedTMinutes = Math.round(tMinutes * 100) / 100;

                const pressure = generateEmulatorPressure(room);
                if (pressure === null) return;

                room.currentPressure = pressure;
                updatePressurePanel();

                checkEmulatorPressureStatus(room, pressure, tSeconds);

                chart.data.labels.push(roundedTMinutes.toFixed(2));
                chart.data.datasets[0].data.push({ x: roundedTMinutes, y: pressure });
                
                room.data.push({ t: tSeconds, pressure });

                updateEmulatorMinMaxLines(room, chart, tSeconds);

                const cutoffTimeSeconds = Math.round((tSeconds - windowSize) * 100) / 100;
                const cutoffTimeMinutes = cutoffTimeSeconds * SEC_TO_MIN;
                
                while (chart.data.labels.length > 0 && parseFloat(chart.data.labels[0]) < cutoffTimeMinutes - 0.01) {
                    chart.data.labels.shift();
                    chart.data.datasets[0].data.shift();
                }

                chart.options.scales.x.min = Math.max(0, cutoffTimeMinutes);
                chart.options.scales.x.max = roundedTMinutes;
                
                chart.update();
            });
            
            if (!anyRunning && emulatorIntervalId) {
                clearInterval(emulatorIntervalId);
                emulatorIntervalId = null;
                document.getElementById('emulatorStartBtn').disabled = false;
                document.getElementById('emulatorStartBtn').style.opacity = '1';
                addEmulatorLogEntry(1, 'info', 'emulationStopped');
            }
        }

        // Р­РєСЃРїРѕСЂС‚ РґР°РЅРЅС‹С… СЌРјСѓР»СЏС‚РѕСЂР° РІ CSV РґР»СЏ РєРѕРЅРєСЂРµС‚РЅРѕРіРѕ РїРѕРјРµС‰РµРЅРёСЏ
        function exportEmulatorCSV(roomIndex) {
            const room = emulatorRooms[roomIndex - 1];
            if (!room || room.data.length === 0) {
                alert('РќРµС‚ РґР°РЅРЅС‹С… РґР»СЏ СЌРєСЃРїРѕСЂС‚Р°. Р—Р°РїСѓСЃС‚РёС‚Рµ СЌРјСѓР»СЏС†РёСЋ.');
                return;
            }
            
            const csvContent = 'Р’СЂРµРјСЏ (РјРёРЅ),Р”Р°РІР»РµРЅРёРµ (РџР°)\n' +
                room.data.map(row => {
                    const minutes = (row.t * SEC_TO_MIN).toFixed(2);
                    return `${minutes},${row.pressure.toFixed(2)}`;
                }).join('\n');

            const blob = new Blob(['\uFEFF' + csvContent], { type: 'text/csv;charset=utf-8;' });
            const link = document.createElement('a');
            link.href = URL.createObjectURL(blob);
            link.download = `emulator_room_${roomIndex}_${new Date().toISOString().slice(0,19).replace(/:/g, '-')}.csv`;
            link.click();
            
            setTimeout(() => URL.revokeObjectURL(link.href), 100);
            
            addEmulatorLogEntry(roomIndex, 'info', 'exportedData', null);
        }

