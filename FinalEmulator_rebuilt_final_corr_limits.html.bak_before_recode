// RU: РґРёР°РїР°Р·РѕРЅ РєРѕСЂСЂРµРєС†РёРё: [-20; +20] РџР°
// EN: correction range: [-20; +20] Pa
// CN: дї®ж­ЈиЊѓе›ґ: [-20; +20] Pa
const CORRECTION_MIN = -20;
const CORRECTION_MAX = 20;

function clampCorrection(n) {
    if (!Number.isFinite(n)) return 0;
    if (n < CORRECTION_MIN) return CORRECTION_MIN;
    if (n > CORRECTION_MAX) return CORRECTION_MAX;
    return n;
}

function formatSignedInt(n) {
    const v = Math.round(n);
    return (v >= 0 ? '+' : '') + String(v);
}

function setCorrectionInputState(inputEl, isCorrected) {
    if (!inputEl) return;
    inputEl.classList.toggle('corrected', !!isCorrected);
}

function setPressureRowCorrectedByKey(dataKey, isCorrected) {
    const label = document.querySelector(`[data-key="${dataKey}"]`);
    if (!label) return;
    const row = label.closest('.pressure-row');
    if (!row) return;
    row.classList.toggle('corrected', !!isCorrected);
}

function setHepaRowCorrected(isCorrected) {
    const hepaRow = document.querySelector('.pressure-block .pressure-row');
    if (!hepaRow) return;
    hepaRow.classList.toggle('corrected', !!isCorrected);
}


