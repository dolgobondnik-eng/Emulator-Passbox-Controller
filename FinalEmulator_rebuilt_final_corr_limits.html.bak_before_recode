let dpPriority = 'dp1';
let pressureAlarmDelaySeconds = 3;

function parseSignedNumber(value) {
    const s = String(value || '').replace(',', '.').trim();
    const n = parseFloat(s);
    return Number.isFinite(n) ? n : 0;
}

function setDPPriority(priority) {
    dpPriority = priority === 'dp2' ? 'dp2' : 'dp1';
    const b1 = document.getElementById('dpPriorityDP1');
    const b2 = document.getElementById('dpPriorityDP2');
    if (b1 && b2) {
        if (dpPriority === 'dp1') { b1.classList.add('active'); b2.classList.remove('active'); }
        else { b2.classList.add('active'); b1.classList.remove('active'); }
    }
}

function savePressureAlarmDelay() {
    const el = document.getElementById('pressureAlarmDelayInput');
    if (!el) return;
    const v = parseInt(String(el.value).trim(), 10);
    pressureAlarmDelaySeconds = Number.isFinite(v) && v >= 0 ? v : 0;
    el.value = String(pressureAlarmDelaySeconds);
}

function bindCorrectionInputs() {
    const filterEl = document.getElementById('corrFilter');
    const dp1El = document.getElementById('corrDP1');
    const dp2El = document.getElementById('corrDP2');

    // RU: СЃС‚Р°РІРёРј HTML-РѕРіСЂР°РЅРёС‡РµРЅРёСЏ, РґР°Р¶Рµ РµСЃР»Рё input=text (РЅРµ РІР»РёСЏРµС‚ РЅР° СЃС‚РёР»Рё)
    // EN: set HTML limits even for type=text (no visual change)
    // CN: и®ѕзЅ®HTMLй™ђе€¶пј€дёЌеЅ±е“Ќж ·ејЏпј‰
    [filterEl, dp1El, dp2El].forEach(el => {
        if (!el) return;
        el.setAttribute('inputmode', 'numeric');
        el.setAttribute('autocomplete', 'off');
    });

    function applyClampAndRefresh() {
        // clamp + normalize values
        filterCorrection = clampCorrection(parseSignedNumber(filterEl?.value));
        dpCorrection1 = clampCorrection(parseSignedNumber(dp1El?.value));
        dpCorrection2 = clampCorrection(parseSignedNumber(dp2El?.value));

        if (filterEl) filterEl.value = formatSignedInt(filterCorrection);
        if (dp1El) dp1El.value = formatSignedInt(dpCorrection1);
        if (dp2El) dp2El.value = formatSignedInt(dpCorrection2);

        // visual indication on inputs
        setCorrectionInputState(filterEl, filterCorrection !== 0);
        setCorrectionInputState(dp1El, dpCorrection1 !== 0);
        setCorrectionInputState(dp2El, dpCorrection2 !== 0);

        // visual indication on displayed rows
        setHepaRowCorrected(filterCorrection !== 0);
        setPressureRowCorrectedByKey('pressureRoom1', dpCorrection1 !== 0);
        setPressureRowCorrectedByKey('pressureRoom2', dpCorrection2 !== 0);

        updatePressurePanel();
    }

    if (filterEl) {
        filterEl.addEventListener('input', applyClampAndRefresh);
        filterEl.addEventListener('change', applyClampAndRefresh);
    }
    if (dp1El) {
        dp1El.addEventListener('input', applyClampAndRefresh);
        dp1El.addEventListener('change', applyClampAndRefresh);
    }
    if (dp2El) {
        dp2El.addEventListener('input', applyClampAndRefresh);
        dp2El.addEventListener('change', applyClampAndRefresh);
    }

    // initial sync
    applyClampAndRefresh();
}

