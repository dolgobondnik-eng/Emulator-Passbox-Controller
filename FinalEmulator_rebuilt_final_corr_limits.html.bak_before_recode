        // РћР±РЅРѕРІР»РµРЅРёРµ Р»РёРЅРёР№ СЂР°Р±РѕС‡РёС… РіСЂР°РЅРёС† СЌРјСѓР»СЏС‚РѕСЂР°
        function updateEmulatorMinMaxLines(room, chart, currentTimeSeconds) {
            if (!chart) return;
            
            const t = currentTimeSeconds || room.currentTime || 0;
            const tMinutes = t * SEC_TO_MIN;
            const roundedTMinutes = Math.round(tMinutes * 100) / 100;
            
            const minLineData = [
                { x: Math.max(0, tMinutes - windowSizeMinutes), y: room.workMin },
                { x: roundedTMinutes, y: room.workMin }
            ];
            const maxLineData = [
                { x: Math.max(0, tMinutes - windowSizeMinutes), y: room.workMax },
                { x: roundedTMinutes, y: room.workMax }
            ];
            
            chart.data.datasets[1].data = minLineData;
            chart.data.datasets[2].data = maxLineData;
        }

        // Р¤СѓРЅРєС†РёСЏ РіРµРЅРµСЂР°С†РёРё РЅРѕРІРѕРіРѕ Р·РЅР°С‡РµРЅРёСЏ РґР°РІР»РµРЅРёСЏ РґР»СЏ СЌРјСѓР»СЏС‚РѕСЂР°
        function generateEmulatorPressure(room) {
            if (!room.isRunning) return null;
            
            if (room.lastPressure === null) {
                room.lastPressure = (room.workMin + room.workMax) / 2;
                room.targetPressure = room.lastPressure;
                room.currentPressure = room.lastPressure;
                room.statusStartTime = 0;
            }
            
            if (room.targetPressure === null || Math.random() < 0.05 * room.speed) {
                const shouldOvershoot = Math.random() < room.overshoot;
                
                if (shouldOvershoot) {
                    const range = room.max - room.min;
                    const workRange = room.workMax - room.workMin;
                    
                    if (Math.random() < 0.5) {
                        room.targetPressure = room.workMax + Math.random() * (range - workRange) * 0.7;
                    } else {
                        room.targetPressure = room.workMin - Math.random() * (range - workRange) * 0.7;
                    }
                    
                    room.targetPressure = Math.max(room.min, Math.min(room.max, room.targetPressure));
                } else {
                    room.targetPressure = Math.random() * (room.workMax - room.workMin) + room.workMin;
                }
            }
            
            const delta = room.targetPressure - room.lastPressure;
            const step = delta * (0.05 * room.speed) * (1 - room.smoothness * 0.8);
            
            room.lastPressure += step;
            
            const noise = (Math.random() - 0.5) * 0.3 * room.speed;
            let newPressure = room.lastPressure + noise;
            
            newPressure = Math.max(room.min, Math.min(room.max, newPressure));
            
            return newPressure;
        }

        // Р—Р°РїСѓСЃРє СЌРјСѓР»СЏС‚РѕСЂР°
        
        /**
         * RU: Р“Р°СЂР°РЅС‚РёСЂСѓРµРј, С‡С‚Рѕ РіСЂР°С„РёРєРё СЌРјСѓР»СЏС‚РѕСЂР° РёРЅРёС†РёР°Р»РёР·РёСЂРѕРІР°РЅС‹ (Chart.js Р·Р°РіСЂСѓР¶РµРЅ, canvas РЅР°Р№РґРµРЅ).
         * EN: Ensure emulator charts are initialized (Chart.js loaded, canvas exists).
         * CN: зЎ®дїќжЁЎж‹џе›ѕиЎЁе·Іе€ќе§‹еЊ–пј€е·ІеЉ иЅЅ Chart.jsпјЊе·Іж‰ѕе€°з”»еёѓпј‰гЂ‚
         *
